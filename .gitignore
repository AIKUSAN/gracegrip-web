# ============================================================
# GraceGrip WebApp — .gitignore
# Ruthless. Nothing sensitive, generated, or ephemeral ships.
# ============================================================

# ─── Secrets & Environment ───────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx
secrets/
.secrets

# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js Build Outputs ───────────────────────────────────
.next/
out/
dist/
dist-ssr/

# ─── Testing & Coverage ──────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ─── Deployment Platforms ────────────────────────────────────
.vercel
.netlify
.azure/

# ─── Turborepo ───────────────────────────────────────────────
.turbo/

# ─── Debug Logs ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS Artifacts ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak
*.tmp

# ─── Local Build Artifacts ───────────────────────────────────
*.local
build/
tmp/
temp/
.cache/

# ─── Diagnostic & Audit Dumps ────────────────────────────────
*.heapsnapshot
*.cpuprofile
audit-report.json

# ─── Local AI / MCP Tool Artifacts ──────────────────────────
.playwright-mcp/
.mcp-debug-tools/

# ─── Internal Docs (agent notes, audit trails, handovers) ────
internal_docs/
handover_to_devops/
.claude/
.specstory/
.claude/settings.local.json

.vercel
